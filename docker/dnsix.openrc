#!/sbin/openrc-run

name="dnsix"
description="Rust DNS64 with CDN IPv6 tricks"

command="/usr/local/bin/dnsix"
command_args="--config /etc/dnsix/config.toml"
supervisor="supervise-daemon"
pidfile="/run/dnsix.pid"
respawn_delay=3
respawn_max=0
output_log="/var/log/dnsix.log"
error_log="/var/log/dnsix.log"

depend() {
	need net
	use dns logger
	after firewall
}
